e":401,"indent":0,"parameters":["――私の名前はレトロ"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「そう…レトロっていうの」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「どうして私なんて…人間なんて助けたの」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「レトロにとって人間は餌なんじゃないの」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["――助けたいと思ったから助けたんだ…"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「…”助けたいと思ったから助けた”…？"]},{"code":401,"indent":0,"parameters":["　ふぅん…変なの」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「でもありがとう…お陰で助かった」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["――この懐中時計も海底に落ちていたんだが、お前のか？"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「え？落とし物…？」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「それ、私のだ…！"]},{"code":401,"indent":0,"parameters":["　拾ってくれたんだ…ありがとう」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「真ん中の青い石が綺麗でしょ"]},{"code":401,"indent":0,"parameters":["　お願い事をすると、一つだけ叶えてくれるんだって」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「…ねぇ、良かったらそれ、レトロが持ってて"]},{"code":401,"indent":0,"parameters":["　助けてくれたお礼」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["――懐中時計はお前の大切なものじゃないのか？"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「逆だよ、私の大切なものだから"]},{"code":401,"indent":0,"parameters":["　レトロに持っててほしい」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「レトロは…何をお願いするの？」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["――願いか…”皆が幸せに生きていける世界が欲しい”…"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「え？それがお願いなの？」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["「ふふ…やっぱり、レトロは変な奴だ」"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["―――あそこだ！小さい女の子がサメに襲われてるぞ！"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["―――助けろ！"]},{"code":101,"indent":0,"parameters":["",0,1,1,""]},{"code":401,"indent":0,"parameters":["―――早くしなきゃ！あの子、食べられちゃうわ！"]},{"code":101,"indent":0,"parameters":["",0,2,2,""]},{"code":401,"indent":0,"parameters":["【スーズ】"]},{"code":401,"indent":0,"parameters":["レト…ロ…"]},{"code":121,"indent":0,"parameters":[192,192,0]},{"code":205,"indent":0,"parameters":[12,{"list":[{"code":29,"parameters":[4],"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":29,"parameters":[4],"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":2,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":2,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":2,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":2,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":2,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":2,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":2,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":2,"indent":null}]},{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":35,"indent":null},{"code":29,"parameters":[4],"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},